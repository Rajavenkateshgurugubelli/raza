# R.A.Z.A. Environment Variables
# Copy this file to .env and fill in your actual keys

# Required: Google AI API Key for Gemini (Get it free at https://aistudio.google.com/)
GOOGLE_API_KEY=your_key_here

# Optional: Override the default Gemini model
MODEL_NAME=gemini-1.5-flash

# Optional: Path for the SQLite memory database
MEMORY_DB_PATH=raza_memory.db

# Optional: Max messages per session in context window
MAX_MEMORY_MESSAGES=50
