# R.A.Z.A. Environment Variables
# Copy this file to .env and fill in your actual keys

# Required (recommended): Google AI API key for Gemini free tier
GOOGLE_API_KEY=your_key_here

# Optional fallback provider key
ANTHROPIC_API_KEY=

# Optional: override model (default is Gemini)
MODEL_NAME=gemini-2.0-flash

# Optional: provider preference order for auto-routing
PROVIDER_ORDER=gemini,anthropic

# Optional: OAuth access token for Gmail/Calendar tools
GOOGLE_OAUTH_ACCESS_TOKEN=

# Optional: Path for the SQLite memory database
MEMORY_DB_PATH=raza_memory.db

# Optional: Max messages per session in context window
MAX_MEMORY_MESSAGES=50

# Optional: Keep this many latest messages uncompressed
RECENT_CONTEXT_MESSAGES=20
